{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: Debug Server",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${env:LOCALAPPDATA}\\Programs\\nodejs\\node.exe",
      "program": "${workspaceFolder}\\node_modules\\next\\dist\\bin\\next",
      "args": [
        "dev",
        "--hostname",
        "127.0.0.1",
        "--port",
        "3000"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Next.js: Debug Full Stack (Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --hostname 127.0.0.1 --port 3000",
      "env": {
        "PATH": "${env:LOCALAPPDATA}\\Programs\\nodejs;${env:PATH}"
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "- Local:.+(https?://.+)",
        "uriFormat": "%s",
        "webRoot": "${workspaceFolder}",
        "killOnServerStop": true
      }
    }
  ]
}
